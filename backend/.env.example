# Service routing (Coolify / Traefik)
SERVICE_FQDN_WEB=api.security.ait.dtu.dk
SERVICE_URL_WEB=https://api.security.ait.dtu.dk

# Traefik network override (only change if your proxy uses a different network name)
TRAEFIK_NETWORK=coolify

# Django configuration
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.security.ait.dtu.dk
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://api.security.ait.dtu.dk
DJANGO_CSRF_COOKIE_DOMAIN=
DJANGO_DEBUG=false
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true
DJANGO_STATIC_ROOT=/mnt/shared-project-data/django/staticfiles
DJANGO_MEDIA_ROOT=/mnt/shared-project-data/django/mediafiles

# Development container identity
DEVCONTAINER_GITHUB_NAME="Your Name"
DEVCONTAINER_GITHUB_EMAIL=you@example.com

# ----- docker-compose environment variables -- starts here ----- #
# Use the same credentials for both the web and database services.
# Change these values in production and update the database password accordingly.
POSTGRES_DB=api_security_dtu_dk
POSTGRES_USER=api_security_dtu_dk_user
POSTGRES_PASSWORD=please-change-me
POSTGRES_HOST=xx-api-security-ait-dtu-dk-postgres-service
# ----- docker-compose environment variables -- ends here ----- #

# Django bootstrap and administration
DJANGO_ADM_VICRE_INIT_TOKEN=
DJANGO_ADM_DAST_INIT_TOKEN=
DJANGO_SUPERUSER_USERNAME=
DJANGO_SUPERUSER_PASSWORD=
DJANGO_ADMIN_USERNAME=
DJANGO_ADMIN_PASSWORD=
DJANGO_SECRET=
DJANGO_SUPERUSER_APIKEY=
SCCM_USERNAME=
SCCM_PASSWORD=

# Third-party APIs
OPENAI_API_KEY=

# Supabase (third-party data store)
SUPABASE_URL=https://supabase-ait-pdomw03.security.ait.dtu.dk
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Local tooling credentials
DOCKERUSER_UID=65000
DOCKERUSER_GID=65000
NGROK_AUTHTOKEN=

# Active Directory integration
ACTIVE_DIRECTORY_USERNAME=
ACTIVE_DIRECTORY_SERVER=ldaps://win.dtu.dk
ACTIVE_DIRECTORY_PASSWORD=
# Optional LDAP timeouts in seconds
ACTIVE_DIRECTORY_CONNECT_TIMEOUT=5
ACTIVE_DIRECTORY_RECEIVE_TIMEOUT=10
ACTIVE_DIRECTORY_SEARCH_TIMEOUT=15
# Comma or semicolon separated list. Defaults to API-SECURITY OU if unset.
AD_GROUP_SYNC_BASE_DNS=OU=API-SECURITY-AIT-DTU-DK,OU=Groups,OU=SOC,OU=CIS,OU=AIT,DC=win,DC=dtu,DC=dk
# Cache TTL (seconds) for AD group sync and per-user group lists
AD_GROUP_CACHE_TIMEOUT=900
AD_GROUP_AUTO_SYNC_ENABLED=false
AD_GROUP_SYNC_REFRESH_MEMBERS=false

# ------ Azure Global ------ #
AZURE_TENANT_ID=
# ------ Azure Global ------ #

# ----- Azure MSAL Starts here ----- #
AIT_SOC_MSAL_VICRE_CLIENT_ID=
AIT_SOC_MSAL_VICRE_MSAL_SECRET_VALUE=
AIT_SOC_MSAL_VICRE_MSAL_SECRET_ID=
AIT_SOC_MSAL_VICRE_AUTHORITY=https://login.microsoftonline.com/
# ----- Azure MSAL Ends here ----- #

# ----- Azure GRAPH API Starts here ----- #
# Client credentials used to obtain access tokens. Tokens are persisted in the DB.
GRAPH_RESOURCE=https://graph.microsoft.com
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_GRANT_TYPE=client_credentials
# Timeout (seconds) for Microsoft Graph login callback requests
AZURE_GRAPH_TIMEOUT=10
# Optional tuning: pre-emptive refresh buffer and default TTL when the token response
# does not include an expiry. Values are seconds. Defaults: 120s buffer, 3600s TTL.
# GRAPH_ACCESS_BEARER_TOKEN_REFRESH_BUFFER=120
# GRAPH_ACCESS_BEARER_TOKEN_TTL=3600
# Note: GRAPH_ACCESS_BEARER_TOKEN and *_EXPIRES_ON are deprecated; tokens are stored in DB.
# ----- Azure GRAPH API Ends here ----- #

# ----- Azure DEFENDER API Starts here ----- #
DEFENDER_RESOURCE=https://api.securitycenter.microsoft.com
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=
DEFENDER_GRANT_TYPE=client_credentials
# Optional tuning
# DEFENDER_ACCESS_BEARER_TOKEN_REFRESH_BUFFER=120
# DEFENDER_ACCESS_BEARER_TOKEN_TTL=3600
# Note: DEFENDER_ACCESS_BEARER_TOKEN and *_EXPIRES_ON are deprecated; tokens are stored in DB.
# ----- Azure DEFENDER API Ends here ----- #
